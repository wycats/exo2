{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "Bundler",
    "noEmit": true,
    "checkJs": true,
    "allowJs": true,
    "types": ["svelte", "vite/client"],
    "paths": {
      "@exosuit/core/Logger.ts": ["../../../exosuit-core/src/Logger.ts"]
    }
  },
  "include": [
    "./**/*",
    "../types/**/*"
  ]
}
